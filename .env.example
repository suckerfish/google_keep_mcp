# Google Keep credentials (see scripts/get_master_token.py to generate)
GOOGLE_KEEP_EMAIL=you@gmail.com
GOOGLE_KEEP_MASTER_TOKEN=your-master-token-here
GOOGLE_KEEP_DEVICE_ID=your-pinned-device-id-here

# Optional: cache Keep state to disk for faster startup
GOOGLE_KEEP_STATE_PATH=./.keep_state.json

# Optional: server configuration
PORT=8080
LOG_LEVEL=INFO
